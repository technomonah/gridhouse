# Telegram — get from https://my.telegram.org/apps
TG_API_ID=       # integer app ID
TG_API_HASH=     # string app hash

# Anthropic — get from https://console.anthropic.com
ANTHROPIC_API_KEY=

# MinIO — object storage credentials
# Used by both MinIO itself and Nessie to connect to it
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# HH.ru OAuth — register app at https://dev.hh.ru
HH_CLIENT_ID=
HH_CLIENT_SECRET=
