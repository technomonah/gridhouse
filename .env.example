# Telegram — get from https://my.telegram.org/apps
TG_API_ID=       # integer app ID
TG_API_HASH=     # string app hash

# Anthropic — get from https://console.anthropic.com
ANTHROPIC_API_KEY=

# MinIO — object storage credentials
# Used by both MinIO itself and Nessie to connect to it
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# HH.ru OAuth — register app at https://dev.hh.ru
HH_CLIENT_ID=
HH_CLIENT_SECRET=

# Telegram alert bot — for priority_apply vacancy notifications
# Create bot via @BotFather, get chat_id from /getUpdates after sending /start
TG_ALERT_BOT_TOKEN=   # bot token from BotFather
TG_ALERT_CHAT_ID=     # your personal chat_id (integer)

# HH.ru scraper — anti-bot randomization tuning
HH_PAGE_DELAY=0.5             # base delay between pages (actual: uniform * [0.5, 2.0])
HH_BETWEEN_QUERY_DELAY_MAX=3.0 # max seconds between different search queries

# LinkedIn extractor (Selenium-based, no API key required)
# Cookies: export from linkedin.com via Cookie-Editor extension → JSON format
LINKEDIN_COOKIES_FILE=   # absolute path to linkedin-cookies.json (default: gridhouse root)
LINKEDIN_SESSION_DIR=    # Chrome profile dir for persistent session (default: gridhouse/linkedin-session)
LINKEDIN_CHROME_BIN=     # path to Chrome binary (default: /Applications/Google Chrome.app/...)
LINKEDIN_QUERY_LIMIT=20  # max posts per query per run
