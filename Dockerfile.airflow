FROM apache/airflow:3.2.0-python3.11

# Install extractor dependencies at build time — avoids slow pip install on every container start.
# Conflicts with pre-installed packages are warnings only (gcsfs/fsspec, httpcore/h11).
RUN pip install --no-cache-dir \
    'pyiceberg>=0.7' \
    'pyarrow>=15.0' \
    's3fs' \
    'boto3' \
    'selenium' \
    'telethon>=1.36' \
    'apache-airflow-providers-ssh'
